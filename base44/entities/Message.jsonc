{
  "name": "Message",
  "type": "object",
  "properties": {
    "campaign_id": {
      "type": "string",
      "description": "Foreign key to Campaign"
    },
    "sender": {
      "type": "string",
      "enum": [
        "System",
        "Client"
      ]
    },
    "message_body": {
      "type": "string"
    },
    "token_cost": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "campaign_id",
    "sender",
    "message_body"
  ]
}